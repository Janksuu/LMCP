{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LMCP Registry Schema",
  "type": "object",
  "required": ["lmcp", "clients", "servers"],
  "properties": {
    "lmcp": {
      "type": "object",
      "required": ["host", "port", "audit_log", "loopback_only"],
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "audit_log": { "type": "string" },
        "loopback_only": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "clients": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["token", "allow_servers"],
        "properties": {
          "token": { "type": "string", "minLength": 1 },
          "allow_servers": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "servers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["transport"],
        "properties": {
          "transport": { "type": "string", "enum": ["stdio", "http"] },
          "command": { "type": ["string", "null"] },
          "args": { "type": "array", "items": { "type": "string" } },
          "env": { "type": "object", "additionalProperties": { "type": "string" } },
          "cwd": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "headers": { "type": "object", "additionalProperties": { "type": "string" } },
          "stdio_mode": { "type": "string", "enum": ["newline", "content-length"] },
          "tool_policy": {
            "type": "object",
            "properties": {
              "mode": { "type": "string", "enum": ["allow_all", "deny_all", "allow_list"] },
              "allow_tools": { "type": "array", "items": { "type": "string" } },
              "deny_tools": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
